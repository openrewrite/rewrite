<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>

    <!-- NuGet package metadata -->
    <IsPackable>true</IsPackable>
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>rewrite-csharp</ToolCommandName>
    <PackageId>OpenRewrite.CSharp.Tool</PackageId>
    <Version>0.0.0</Version>
    <Authors>Moderne</Authors>
    <Description>CLI tool for OpenRewrite C# language support (RPC server)</Description>
    <PackageProjectUrl>https://docs.openrewrite.org</PackageProjectUrl>
    <RepositoryUrl>https://github.com/openrewrite/rewrite</RepositoryUrl>
    <PackageTags>openrewrite;refactoring;csharp;dotnet</PackageTags>
    <NoPackageAnalysis>true</NoPackageAnalysis>
  </PropertyGroup>

  <PropertyGroup>
    <OpenRewriteSdkSourcePath Condition="'$(OpenRewriteSdkSourcePath)' == ''">../OpenRewrite/OpenRewrite.csproj</OpenRewriteSdkSourcePath>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="$(OpenRewriteSdkSourcePath)" />
  </ItemGroup>

  <ItemGroup>
    <!-- Keep MSBuild assemblies out of the output so MSBuildLocator can load the SDK's copies
         for in-process restore-graph evaluation (NuGetResolver). A stale app-base copy of
         Microsoft.Build.Framework causes MissingMethodException at MSBuild load time. -->
    <PackageReference Include="Microsoft.Build" Version="18.8.2" ExcludeAssets="runtime" />
    <PackageReference Include="Microsoft.Build.Framework" Version="18.8.2" ExcludeAssets="runtime" />
  </ItemGroup>

</Project>
